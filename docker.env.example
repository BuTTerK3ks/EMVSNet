# Docker Environment Variables Template
# Copy this file to docker.env and customize for your setup

# ============================================
# Data and Output Paths
# ============================================
# Path to training data on host (mounted to /workspace/data in container; DTU at mvs_training/dtu under that)
# Used as volume source when HOST_DATA_PATH is unset
DATA_PATH=/path/to/your/training/data
HOST_DATA_PATH=/path/to/your/training/data

# Path for outputs (checkpoints, logs) on host (will be mounted to /workspace/output)
OUTPUT_PATH=/path/to/output/directory

# ============================================
# GPU Configuration
# ============================================
# GPU IDs to use (e.g., "0" for single GPU, "0,1" for multi-GPU)
CUDA_VISIBLE_DEVICES=0

# Number of GPUs (for docker-compose resource allocation)
GPU_COUNT=1

# ============================================
# Training Parameters (Optional)
# ============================================
# These can also be passed as command-line arguments
# BATCH_SIZE=1
# EPOCHS=10
# LEARNING_RATE=0.001
# NUM_DEPTH=128
# VIEW_NUM=5

# ============================================
# Python Configuration
# ============================================
PYTHONUNBUFFERED=1
PYTHONNOUSERSITE=1
PYTHONFAULTHANDLER=1

# ============================================
# PyTorch Configuration
# ============================================
TORCH_SHOW_CPP_STACKTRACES=1
